        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <UserSecretsId>e77b95ab-ecf7-486f-8e4b-4fe64a167a10</UserSecretsId>
        <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="FastEndpoints" Version="8.0.1"/>
        <PackageReference Include="FastEndpoints.Swagger" Version="8.0.1"/>
        <PackageReference Include="FluentValidation" Version="12.1.1"/>
        <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="10.0.5"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\WordsmithHub.Domain\WordsmithHub.Domain.csproj"/>
        <ProjectReference Include="..\WordsmithHub.Infrastructure\WordsmithHub.Infrastructure.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <Folder Include="Features\User\Add\"/>
