    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\WordsmithHub.Domain\WordsmithHub.Domain.csproj"/>
        <ProjectReference Include="..\WordsmithHub.Infrastructure\WordsmithHub.Infrastructure.csproj"/>
