        <Folder Include="Features\User\GetAll\"/>
        <Folder Include="Features\User\Update\"/>
    </ItemGroup>

    <ItemGroup>
        <Content Include="..\.dockerignore">
            <Link>.dockerignore</Link>
        </Content>
    </ItemGroup>

</Project>
